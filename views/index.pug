extends layout

block additionalMenuRight  
  +langMenu(2)


block content
  // Full Access Index Page
  .div
    .row.align-items-start
      .col-12.col-xl-6
          h2.d-none.d-sm-block
            | Welcome to OSM BC
          p.osmbc-help-text.d-none.d-sm-block
            | See recent blogs to work on below. If you just want to collect an article or an idea, use the collect menu on in the navbar.
          h3="Blogs to work on "
            a(href=layout.htmlroot+"/blog/list?status=IN(open,edit)") (more)
          div
            +blogStatusTable(true, true)
          .mt-1.mb-2
            small.osmbc-help-text Badge legend
            table.table.table-sm.w-auto.mb-0
              tbody
                tr
                  td.text-center.align-middle
                    span.badge.osmbc-label-openblog open
                  td.text-start.align-middle 
                    span.osmbc-help-text number of pending articles in open blogs
                tr
                  td.text-center.align-middle
                    span.badge.osmbc-not-formulated edit
                  td.text-start.align-middle.osmbc-help-text 
                    span.osmbc-help-text number of pending articles in edit blogs
                tr
                  td.text-center.align-middle
                    span.badge.osmbc-automated-translation auto
                  td.text-start.align-middle.osmbc-help-text 
                    span.osmbc-help-text number of automated translations
                tr
                  td.text-center.align-middle
                    span.badge.osmbc-label-reviewblog review
                  td.text-start.align-middle.osmbc-help-text 
                    span.osmbc-help-text number of reviews
                tr
                  td.text-center.align-middle
                    span.badge.osmbc-label-closedblog
                      i.fa.fa-check
                  td.text-start.align-middle.osmbc-help-text 
                    span.osmbc-help-text language is closed
          h4="Current Users"
          p
            table.table
              for user, i in activeUserList
                tr
                  td
                    img(src=layout.getAvatar(user.OSMUser) style="height:25px;width:25px")
                  td=user.OSMUser +" "
                  td.text-body-secondary=layout.moment(user.lastAccess).fromNow()
          
          if (fullVisitorsToday && fullVisitorsToday.length>0)
            h4="Full Visitors Today"
            p
              table.table
                tr
                  td
                    for user,i in fullVisitorsToday
                      span
                        a(href=layout.htmlroot+"/usert/"+user.OSMUser)=user.OSMUser
                        span=", "
            if (guestVisitorsToday && guestVisitorsToday.length>0)
              h4="Guest Visitors Today"
              p
                table.table
                  tr
                    td
                      for user,i in guestVisitorsToday
                        span
                          a(href=layout.htmlroot + "/usert/" + user.OSMUser)=user.OSMUser
                          span=", "
          if (newUsers && newUsers.length>0)
            .row
              h4="Welcome To The Team"
              p
                table.table
                  for user,i in newUsers
                    tr
                      td
                        img(src=layout.getAvatar(user.osmuser) style="height:25px;width:25px")
                      td
                        a(href=layout.htmlroot+"/usert/"+user.osmuser)=user.osmuser
                      td
                        a(href=layout.htmlroot+"/changes/log?user="+user.osmuser) edits
                      td
                        a(href="https://www.openstreetmap.org/user/"+user.osmuser)
                          i.fa.fa-map.text-body-secondary
                      td
                        a(href="https://hdyc.neis-one.org/?"+user.osmuser)
                          i.fa.fa-line-chart.text-body-secondary
                      td=user.access




          p.row
            h4="Admin View"
            p
              a#adminlink(href=layout.htmlroot+"/osmbc/admin")="click here" 
              span=" to go to the Admin Section of OSMBC"
      .col-12.col-xl-6.d-none.d-lg-block
        if changes
          h4="Last Changes "
            - var d = new Date();
            - d= d.toISOString();
            - d= d.substring(0,7);
            a(href=layout.htmlroot+"/changes/log?date="+d)  (more)
          table.table.table-striped.table-sm
              thead
                tr 
                  th
                  th blog
                  th user
                  th table
                  th what
                  th Change
                  th when
              tbody
                each change, i in changes
                  tr
                    td
                      a(href=layout.htmlroot+'/changes/' + change.id)
                        i.fa.fa-info-circle
                    td= change.blog
                    td= change.user
                    td= change.table
                    td= change.property
                    td
                      |!{change.htmlDiffText(40)}
                    td= layout.moment(change.timestamp).fromNow()
          p.osmbc-help-text
            span="only displaying changes: "
            span.osmbc-inserted
              | This is inserted text
            span=" "
            span.osmbc-deleted
              | and this is removed text

  div.footer
