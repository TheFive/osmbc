    "mocha": "11.7.x",
    "globals": "17.5.0",
    "mockdate": "3.0.x",
    "nock": "14.0.12",
    "nyc": "^18.0.0",
    "pretty": "^2.0.0",
    "selenium-webdriver": "4.43.0",
