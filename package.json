{
  "name": "osmbc",
  "version": "4.1.10",
  "private": false,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "lint": "eslint --no-error-on-unmatched-pattern app.js staticFileServer.js config.js postinstall.js bin/**/*.js export/**/*.js genstaticpage/**/*.js import/**/*.js model/**/*.js notification/**/*.js render/**/*.js routes/**/*.js scripts/**/*.js test/**/*.js util/**/*.js",
    "start": "NODE_ENV=development node ./bin/www.js",
    "test": "export NODE_ENV=test export TEST_HEADLESS=TRUE export start=`date +%s`; npx nyc mocha; end=`date +%s`; echo $((end-start))",
    "test:model": "NODE_ENV=test TEST_HEADLESS=TRUE npx nyc mocha \"test/model.*.test.js\" \"test/notification.*.test.js\" \"test/render.*.test.js\" \"test/util.test.js\"",
    "test:router": "NODE_ENV=test TEST_HEADLESS=TRUE npx nyc mocha \"test/router.*.test.js\" \"test/routes.*.test.js\"",
    "test:ui": "NODE_ENV=test TEST_HEADLESS=TRUE npx nyc mocha \"test/**/uc.*.test.js\"",
    "test:layers": "npm run test:model && npm run test:router && npm run test:ui",
    "test-github": "NODE_ENV=test TEST_HEADLESS=TRUE mocha -f eslint",
    "staticHtmlServerd": "NODE_ENV=development node ./staticFileServer.js",
    "postinstall": "node ./postinstall.js"
  },
  "dependencies": {
