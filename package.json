    "email-templates": "13.0.1",
    "email-validator": "2.0.x",
    "express": "^5.2.1",
    "express-fileupload": "1.5.2",
    "express-rate-limit": "8.3.2",
    "express-session": "1.19.0",
    "font-awesome": "4.7.x",
    "glob": "13.0.6",
